@charset "utf-8";

div.sect1 { margin-top: 48px; }

figure.wp-block-video { margin-bottom: 30px; }

figure.wp-block-video iframe:not([height]) { height: 342px; }

@media screen and (max-width: 600px) {
  figure.wp-block-video iframe:not([height]) { height: 300px; }
}

@media screen and (max-width: 400px) {
  figure.wp-block-video iframe:not([height]) { height: 200px; }
}

figure.wp-block-video iframe:not([width]) { width: 100%; }

div.wp-block-image { margin-bottom: 20px; }

ol, ul { list-style-position: outside; }

ul { padding-left: 15px; }

ol { padding-left: 25px; }

ol ol, ul ul, ol ul, ul ol { padding-left: 30px; margin-bottom: 0px; }

ul ul { list-style-type: circle; }

ol ol { list-style-type: lower-alpha; }

li p { margin-bottom: 0.25rem; }

dt { font-style: italic; font-weight: bold; }

dd { margin-left: 25px; }

div.admonitionblock { margin-bottom: 20px; }

div.admonitionblock .label { text-transform: uppercase; font-weight: bold; =
font-size: 0.9em; margin-bottom: 8px; }

div.admonitionblock.warning .label { color: rgb(214, 42, 6); }

div.admonitionblock.warning .label::before { content: "=E2=9A=A0 "; }

div.admonitionblock.warning .label::after { content: " =E2=9A=A0"; }

div.admonitionblock.important .label { color: rgb(214, 146, 6); }

div.admonitionblock.note .label { color: rgb(6, 214, 146); }

div.admonitionblock.tip .label { color: rgb(6, 74, 214); }

div.admonitionblock .inner { padding: 15px; border: 3px solid rgb(0, 0, 0);=
 }

div.admonitionblock .inner :last-child { margin-bottom: 0px; }

div.admonitionblock.warning .inner { border-color: rgb(214, 42, 6); }

div.admonitionblock.important .inner { border-color: rgb(214, 146, 6); }

div.admonitionblock.note .inner { border-color: rgb(6, 214, 146); }

div.admonitionblock.tip .inner { border-color: rgb(6, 74, 214); }
