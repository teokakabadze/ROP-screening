</span> <span class=3D"token operator">&gt;</span> <span class=3D"token var=
iable">$wdir</span>/dwMaxVideoFrameBufferSize
	<span class=3D"token function">cat</span> <span class=3D"token operator">&=
lt;&lt;</span><span class=3D"token string">EOF<span class=3D"token bash pun=
ctuation"> <span class=3D"token operator">&gt;</span> <span class=3D"token =
variable">$wdir</span>/dwFrameInterval</span>
<span class=3D"token variable">$6</span>
EOF</span>
<span class=3D"token punctuation">}</span>

